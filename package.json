{
  "name": "network-scanner-pro",
  "version": "1.0.0",
  "author": "NetScan Team",
  "description": "WiFi Network Scanner - Desktop Version",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix frontend\" \"wait-on tcp:5173 && electron .\"",
    "build": "npm run build --prefix frontend && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "bonjour-service": "^1.3.0",
    "dotenv": "^17.4.2",
    "electron-store": "^8.1.0",
    "local-devices": "^4.0.0",
    "mongoose": "^9.6.1",
    "node-telegram-bot-api": "^0.67.0",
    "p-limit": "^2.3.0",
    "ping": "^1.0.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "25.9.8",
    "electron-builder": "^24.4.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.netscan.pro",
    "productName": "NetScan Pro",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "frontend/public/vite.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NetScan Pro"
    }
  }
}
